# =======================================================================
# Example environment file. Copy to `.env` and fill in real values.
# NEVER commit a real `.env`. All values below are placeholders.
# =======================================================================

# =======================================================================
# SUPABASE CLOUD
# =======================================================================
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-jwt...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-jwt...
JWT_SECRET=change-me-32-bytes-base64

# Auth Configuration
SITE_URL=https://your-domain.example.com
ADDITIONAL_REDIRECT_URLS=https://your-domain.example.com

# ========================================================================
# CLOUD STORAGE (S3-compatible, e.g. Yandex Object Storage / AWS S3)
# ========================================================================
S3_REGION=your-region
S3_ENDPOINT=https://s3.example.com
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# Storage Buckets
S3_DEVICE_PCM_BUCKET=device-pcm-prod
S3_SESSIONS_WAV_BUCKET=sessions-wav-prod
S3_INCOMPLETE_TIMELINE_BUCKET=incomplete-timeline-prod

# ========================================================================
# AI & ML SERVICES
# ========================================================================

# Silero VAD (Voice Activity Detection) - internal service
SILERO_VAD_URL=http://silero-vad:8003
SILERO_VAD_PORT=8003

# Hugging Face (used to download the Silero VAD model)
HF_TOKEN=hf_...your-huggingface-token...

# OpenAI (Whisper transcription + LLM analysis run on the OpenAI cloud API)
OPENAI_API_KEY=sk-...your-openai-api-key...

# OpenAI stored prompt IDs
PROMPT_TEXT_OPTIMIZATION_ID=pmpt_your_text_optimization_prompt_id
PROMPT_FULL_ANALYSIS_ID=pmpt_your_full_analysis_prompt_id

# ========================================================================
# THIRD PARTY INTEGRATIONS
# ========================================================================

# Telegram Bot (token from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token

# ========================================================================
# APPLICATION SETTINGS
# ========================================================================

# Build Configuration (release | debug)
SWIFT_BUILD_CONFIG=release

# Minimum session length to be considered complete (seconds).
# Sessions shorter than this are discarded or kept as incomplete.
VAD_MIN_SESSION_LENGTH=15

# Window size for speech-activity analysis (seconds).
# A sliding window analyzes every position of the timeline.
VAD_ACTIVITY_WINDOW=10

# Minimum speech ratio in a window to count as active (0.0-1.0).
# If 20%+ of the window contains speech, the segment is considered active.
VAD_ACTIVITY_THRESHOLD=0.20

# Silence duration after activity that forces session completion (seconds).
# If this many seconds pass after the last activity, all sessions are finalized.
VAD_END_SILENCE_DURATION=60

# ========================================
# Silence trimming parameters
# ========================================

# Maximum silence to keep when trimming long pauses (seconds).
# Long pauses are compressed down to this maximum.
VAD_MAX_INNER_SILENCE=3

# Minimum silence length to trigger inner trimming (seconds).
# Pauses from this length up are subject to compression.
VAD_MIN_SILENCE_TO_TRIM=5

# Buffer time kept around trims for smooth transitions (seconds).
# When trimming, this many seconds are left at the start and end.
VAD_SILENCE_BUFFER=1
